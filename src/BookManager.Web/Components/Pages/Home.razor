@page "/"

@using BookManager.Web.Components.Shared.BookCard
@using BookManager.Web.Components.Shared.Badge

@rendermode InteractiveServer


<PageTitle>Home</PageTitle>

<div class="grid grid-cols-1 gap-6 p-6 w-fit mx-auto sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 justify-items-center">
    @foreach (var book in books)
    {
        <BookCard Book="@book" />
    }
</div>

