@inject TailwindMerge.TwMerge TwMerge

<div class="@ComputedClasses">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label for="@Id" class="text-gray-500 text-sm font-medium leading-none">
            @Label
        </label>
    }

    <input
        id="@Id"
        type="@Type"
        class="bg-gray-100 text-gray-500 body-sm px-3 py-2 rounded-lg outline-none focus:ring-2 focus:ring-gray-200 w-full transition-colors placeholder:text-gray-400 disabled:opacity-50 disabled:cursor-not-allowed"
        @attributes="AdditionalAttributes"
    />
</div>


@code {
    [Parameter]
    public string? ClassName { get; set; }

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public string? Type { get; set; } = "text";

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
    
    private string ComputedClasses => TwMerge.Merge(
        "flex flex-col gap-2",
        ClassName
    ) ?? "";
}