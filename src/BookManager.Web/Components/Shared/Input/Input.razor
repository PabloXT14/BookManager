@inject TailwindMerge.TwMerge TwMerge

<div class="@ComputedClasses">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label for="@Id" class="text-gray-500 text-sm font-medium leading-none">
            @Label
        </label>
    }

    <div class="@TwMerge.Merge(
    "flex items-center gap-3 bg-gray-100 px-3 py-2 rounded-lg focus-within:ring-2 focus-within:ring-gray-200 w-full transition-colors",
        IsDisabled ? "cursor-not-allowed opacity-50" : ""
    )">
        @if (LeftIcon != null)
        {
            <div class="shrink-0">
                @LeftIcon
            </div>
        }

        <input
            id="@Id"
            type="@Type"
            disabled="@IsDisabled"
            class="flex-1 text-gray-500 body-sm outline-none placeholder:text-gray-400 disabled:cursor-not-allowed"
            @attributes="AdditionalAttributes"
        />

        @if (RightIcon != null)
        {
            <div class="shrink-0">
                @RightIcon
            </div>
        }
    </div>    
</div>


@code {
    [Parameter]
    public string? ClassName { get; set; }

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? Id { get; set; }

    [Parameter]
    public string? Type { get; set; } = "text";

    [Parameter]
    public bool IsDisabled { get; set; }

    [Parameter]
    public RenderFragment? LeftIcon { get; set; }

    [Parameter]
    public RenderFragment? RightIcon { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
    
    private string ComputedClasses => TwMerge.Merge(
        "flex flex-col gap-2 w-full",
        ClassName
    ) ?? "";
}